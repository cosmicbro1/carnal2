{
  "model": "gpt-4o-mini",
  "temperature": 0.7,
  "max_tokens": 800,
  
  "llm_provider": "auto",
  "llm_provider_notes": "Priority: 'auto' tries Ollama first (free, local), then Gemma API, then OpenAI",
  
  "ollama": {
    "enabled": true,
    "base_url": "http://localhost:11434",
    "model": "gemma2",
    "notes": "FREE, LOCAL, OPEN SOURCE - Recommended for students. Download from https://ollama.ai"
  },
  
  "gemma_config": {
    "enabled": true,
    "model": "gemini-2.0-flash",
    "temperature": 0.7,
    "max_output_tokens": 800,
    "top_p": 0.95,
    "top_k": 40,
    "notes": "Free API tier (60 req/min). Get key at https://ai.google.dev/gemini-api. Fallback if Ollama unavailable."
  },
  
  "openai_config": {
    "enabled": true,
    "model": "gpt-4o-mini",
    "temperature": 0.7,
    "max_tokens": 800,
    "notes": "Reliable fallback. Better for ultra-long context & edge cases."
  },
  
  "image": {
    "provider": "openai",
    "openai_model": "dall-e-3",
    "a1111_url": "http://127.0.0.1:7860",
    "output_dir": "outputs"
  },
  
  "tts": {
    "enabled": false,
    "engine": "edge-tts",
    "language": "en",
    "voice": "en-US-AriaNeural"
  },
  
  "performance": {
    "ollama_preferred": true,
    "fallback_chain": ["ollama", "gemma", "openai"],
    "log_provider_usage": true,
    "cache_responses": false,
    "stream_responses": false
  },
  
  "features": {
    "healing_mode": true,
    "love_coaching": true,
    "meditation_guided": true,
    "sound_healing": true,
    "journaling": true,
    "chakra_balancing": true,
    "angel_readings": true,
    "tarot_generation": false
  },
  
  "accessibility": {
    "dark_mode": false,
    "voice_playback": false,
    "captions": true,
    "readable_fonts": true,
    "font_size": "medium"
  },
  
  "environment": {
    "notes": "Set API keys in .env file if using cloud APIs",
    "required_keys": [],
    "optional_keys": ["OPENAI_API_KEY", "GOOGLE_API_KEY"],
    "ollama_note": "No API key needed for Ollama - runs locally and free!"
  }
}
